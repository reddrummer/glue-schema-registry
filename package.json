{
  "name": "@drumwave/glue-schema-registry",
  "version": "4.0.0",
  "description": "SerDe library to interact with the AWS Glue Schema Registry. Encode and decode messages with Avro and JSON schema using the AWS wire format.",
  "author": "Drumwave",
  "private": false,
  "license": "MIT",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "scripts": {
    "prepare": "npm run build",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json && node -e \"require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({ type: 'module' }, null, 2))\"",
    "build": "npm run build:cjs && npm run build:esm",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "prettier": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "coverage": "jest --coverage"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": [
    "glue",
    "MSK",
    "Kafka",
    "schema",
    "registry",
    "avro"
  ],
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/node": "^25.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.0.3",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@aws-sdk/client-glue": "^3.298.0",
    "ajv": "^8.18.0",
    "avsc": "^5.7.7",
    "uuid": "^11.0.5"
  }
}
